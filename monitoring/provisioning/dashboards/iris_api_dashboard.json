{
  "title": "Iris API - Overview",
  "schemaVersion": 39,
  "version": 1,
  "time": { "from": "now-15m", "to": "now" },
  "panels": [
    {
      "type": "stat",
      "title": "Total Predictions",
      "gridPos": {"x":0,"y":0,"w":8,"h":6},
      "targets": [{ "expr": "sum(predictions_total)" }]
    },
    {
      "type": "timeseries",
      "title": "Predictions by Class (rate)",
      "gridPos": {"x":8,"y":0,"w":16,"h":6},
      "targets": [
        { "expr": "sum by (class) (rate(predictions_total[1m]))", "legendFormat": "class {{class}}/s" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Latency p50/p95 (seconds)",
      "gridPos": {"x":0,"y":6,"w":24,"h":8},
      "targets": [
        { "expr": "histogram_quantile(0.5, sum(rate(prediction_latency_seconds_bucket[5m])) by (le))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.95, sum(rate(prediction_latency_seconds_bucket[5m])) by (le))", "legendFormat": "p95" }
      ]
    }
  ]
}
